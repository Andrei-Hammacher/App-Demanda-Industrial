<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".SelecaoProjetoActivity">

    <!-- Cabeçalho com contagem -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="@color/surface">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Selecione ou exclua um projeto."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingMultiplier="1.3"/>

        <!-- Badge com contagem de projetos -->
        <TextView
            android:id="@+id/tvContadorProjetos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 projetos"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:background="@color/primary_light"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- Lista de projetos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerProjetos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"
        tools:listitem="@layout/list_item_projeto"/>

    <!-- Empty state — visível quando não há projetos -->
    <LinearLayout
        android:id="@+id/layoutEmptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:visibility="gone">

        <!-- Ícone grande -->
        <TextView
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:text="📂"
            android:textSize="44sp"
            android:gravity="center"
            android:background="@drawable/bg_circle_white_alpha"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nenhum projeto ainda"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Volte à tela inicial e crie\num novo projeto para começar."
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"/>

    </LinearLayout>

</LinearLayout>