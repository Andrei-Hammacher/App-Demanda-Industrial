<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <!-- ═══ CARD HERO: Demanda Total ═══════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/primary"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡  Demanda Total"
                        android:textSize="13sp"
                        android:textColor="#B3D4F5"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvTotalKva"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00 kVA"
                        android:textSize="38sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="16dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#33FFFFFF"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvFatorSimultaneidade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fator C: N/A"
                        android:textSize="11sp"
                        android:textColor="#B3D4F5"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvFpGlobal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="FP Global: --"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>

                        <TextView
                            android:id="@+id/tvAlertaCapacitor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="11sp"
                            android:textStyle="bold"/>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ CARD: Grupos de Demanda ════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/surface"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DEMANDA POR GRUPO"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="12dp"/>

                    <!-- Grupo A -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <View android:layout_width="10dp" android:layout_height="10dp"
                            android:background="@color/stripe_grupo_a"
                            android:layout_marginEnd="10dp"/>
                        <TextView android:id="@+id/tvResumoGrupoA"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Grupo A (Ilum/Tom): 0.00 kVA"
                            android:textSize="14sp" android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <!-- Grupo B -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <View android:layout_width="10dp" android:layout_height="10dp"
                            android:background="@color/stripe_grupo_b"
                            android:layout_marginEnd="10dp"/>
                        <TextView android:id="@+id/tvResumoGrupoB"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Grupo B (Fornos): 0.00 kVA"
                            android:textSize="14sp" android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <!-- Grupo C -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <View android:layout_width="10dp" android:layout_height="10dp"
                            android:background="@color/stripe_grupo_c"
                            android:layout_marginEnd="10dp"/>
                        <TextView android:id="@+id/tvResumoGrupoC"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Grupo C (Motores): 0.00 kVA"
                            android:textSize="14sp" android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <!-- Especiais -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <View android:layout_width="10dp" android:layout_height="10dp"
                            android:background="@color/stripe_especial"
                            android:layout_marginEnd="10dp"/>
                        <TextView android:id="@+id/tvResumoEspeciais"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Especiais: 0.00 kVA"
                            android:textSize="14sp" android:textColor="@color/text_primary"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ CARD: Reserva e Trafo — DESTAQUE ESPECIAL ══════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/surface"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Cabeçalho compacto da seção -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DIMENSIONAMENTO"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="10dp"/>

                        <TextView android:id="@+id/tvReservaCarga"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Reserva (10%): 0.00 kVA"
                            android:textSize="14sp" android:textColor="@color/text_primary"
                            android:layout_marginBottom="4dp"/>

                        <TextView android:id="@+id/tvDemandaFinal"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Demanda c/ Reserva: 0.00 kVA"
                            android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>

                    </LinearLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/primary_light"/>

                    <!-- Destaque do trafo — fundo azul claro + borda forte -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@color/primary_light"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TRANSFORMADOR SUGERIDO"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"
                                android:letterSpacing="0.06"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:id="@+id/tvTrafoSugerido"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"/>
                        </LinearLayout>

                        <!-- Ícone de raio decorativo -->
                        <TextView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="🔌"
                            android:textSize="26sp"
                            android:gravity="center"/>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ CARD: Tomadas por Tipo ═════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/stripe_grupo_a_bg"
                app:strokeColor="@color/stripe_grupo_a"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOMADAS E ILUMINAÇÃO"
                        android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/stripe_grupo_a"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="10dp"/>

                    <TextView android:id="@+id/tvTomadaAdm"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="T1Φ_ADM: 0.00 kVA"
                        android:textSize="13sp" android:textColor="@color/text_primary"
                        android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvTomadaSe"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="T1Φ_SE: 0.00 kVA"
                        android:textSize="13sp" android:textColor="@color/text_primary"
                        android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvTomadaIndMono"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="T1Φ_IND: 0.00 kVA"
                        android:textSize="13sp" android:textColor="@color/text_primary"
                        android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvTomadaIndTri"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="T3Φ_IND: 0.00 kVA"
                        android:textSize="13sp" android:textColor="@color/text_primary"
                        android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvIluminacaoTotal"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Iluminação: 0.00 kVA"
                        android:textSize="13sp" android:textColor="@color/text_primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ CARD: CCM ══════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/stripe_grupo_c_bg"
                app:strokeColor="@color/stripe_grupo_c"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PAINÉIS DE MOTORES (CCM)"
                        android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/stripe_grupo_c"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="10dp"/>

                    <TextView android:id="@+id/tvResumoCcm"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Nenhum motor cadastrado"
                        android:textSize="13sp" android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.6"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ CARD: QDF ══════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/stripe_outros_bg"
                app:strokeColor="@color/stripe_outros"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUADROS DE DISTRIBUIÇÃO (QDF)"
                        android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/stripe_outros"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="10dp"/>

                    <TextView android:id="@+id/tvResumoQdf"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Nenhum equipamento cadastrado"
                        android:textSize="13sp" android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.6"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ CABEÇALHO DA LISTA ═════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EQUIPAMENTOS CADASTRADOS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerCargas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/list_item_equipment"/>

        </LinearLayout>
    </ScrollView>

    <!-- ═══ BARRA FIXA NO RODAPÉ ══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/background"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
        android:elevation="8dp">

        <Button
            android:id="@+id/btnAdicionarCarga"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="+ Adicionar Equipamento"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            style="@style/Widget.App.Button"/>

        <Button
            android:id="@+id/btnExportarPdf"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="📄  Exportar Relatório PDF"
            android:textSize="14sp"
            android:textStyle="bold"
            style="@style/Widget.App.Button.Outlined"/>

    </LinearLayout>

</LinearLayout>