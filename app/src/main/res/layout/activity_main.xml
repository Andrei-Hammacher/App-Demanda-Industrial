<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".MainActivity">

    <!-- ═══ HERO ══════════════════════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_gradient_primary">

        <!-- Círculo decorativo grande — canto superior direito -->
        <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="top|end"
            android:translationX="80dp"
            android:translationY="-60dp"
            android:background="@drawable/bg_hero_circles"/>

        <!-- Círculo médio — canto inferior esquerdo -->
        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="bottom|start"
            android:translationX="-50dp"
            android:translationY="50dp"
            android:background="@drawable/bg_hero_circles"/>

        <!-- Círculo pequeno — centro-direita -->
        <View
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center_vertical|end"
            android:translationX="20dp"
            android:background="@drawable/bg_hero_circles"/>

        <!-- Conteúdo central -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp">

            <!-- Ícone circular -->
            <TextView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="⚡"
                android:textSize="40sp"
                android:gravity="center"
                android:background="@drawable/bg_circle_white_alpha"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DemandaCalc"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.02"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cálculo de Demanda Elétrica Industrial"
                android:textSize="14sp"
                android:textColor="@color/text_on_dark"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"/>

            <!-- Badge decorativo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  NR-10 · NBR 5410  "
                android:textSize="11sp"
                android:textColor="#B3D4F5"
                android:background="@drawable/bg_circle_white_alpha"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginTop="16dp"/>

        </LinearLayout>
    </FrameLayout>

    <!-- ═══ PAINEL DE AÇÕES ══════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/surface"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="36dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bem-vindo"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crie um novo projeto ou acesse os salvos para calcular a demanda elétrica da instalação."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnNovoProjeto"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="+ Criar Novo Projeto"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                style="@style/Widget.App.Button"/>

            <Button
                android:id="@+id/btnVerProjetos"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Ver Projetos Salvos"
                android:textSize="15sp"
                style="@style/Widget.App.Button.Outlined"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>