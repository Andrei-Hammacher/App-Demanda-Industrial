<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardEquipamento"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:minHeight="72dp">

        <!-- Stripe colorida por tipo — cor definida pelo adapter -->
        <View
            android:id="@+id/viewStripe"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:background="@color/primary"/>

        <!-- Conteúdo principal -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- Linha 1: nome em negrito -->
            <TextView
                android:id="@+id/tvNomeEquipamento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Motor Bomba B1 (Motor)"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Linha 2: tipo como label menor -->
            <TextView
                android:id="@+id/tvTipoEquipamento"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Motor"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="6dp"/>

            <!-- Linha 3: detalhes qtd + potencia -->
            <TextView
                android:id="@+id/tvDetalhesEquipamento"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Qtd: 3  ·  10.0 CV/un"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>

        <!-- Lado direito: chip de demanda + botões -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingEnd="8dp">

            <!-- Chip de demanda total -->
            <TextView
                android:id="@+id/tvDemandaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.78 kVA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:background="@drawable/bg_chip_demand"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="6dp"/>

            <!-- Botões de ação -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnEditarEquipamento"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/primary"
                    android:contentDescription="Editar equipamento"/>

                <ImageButton
                    android:id="@+id/btnDeleteEquipamento"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_delete"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/error"
                    android:contentDescription="Excluir equipamento"/>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>